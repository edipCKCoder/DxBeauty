  <data name="tileView1.TileHtmlTemplate.Styles" xml:space="preserve">
    <value>/* Ana Kart İskeleti */
.card-container {
    background-color: #f8f9fa; /* Açık gri/beyaz arka plan */
    border-radius: 10px;       /* Yumuşak köşeler */
    padding: 15px;
    margin-bottom: 10px;       /* Kartlar arası boşluk */
    display: flex;
    justify-content: space-between; /* Sağ ve sol elemanları ayır */
    align-items: center;
    border-left: 5px solid #17a2b8; /* Sol taraftaki şık turkuaz çizgi */
    box-shadow: 0 2px 5px rgba(0,0,0,0.05); /* Çok hafif gölge */
}

/* Yazı Tipleri ve Renkler */
.customer-name {
    font-size: 14px;
    font-weight: bold;
    color: #333;
    margin-bottom: 5px;
}
/* 📞 YENİ EKLENEN CLASS: Telefon numarası için özel stil */
.phone-number {
    font-size: 12px;
    font-weight: 600;        /* Normal detaylardan bir tık daha kalın */
    color: #495057;          /* Koyu, profesyonel ve okunaklı bir gri */
    margin-bottom: 4px;      /* Altındaki elemanla (hizmet detayı) boşluk */
     /* ❗️ KRİTİK: Rakamların bitişmesini engeller, okunabilirliği artırır */
}
.service-detail, .time-detail {
    font-size: 12px;
    color: #666;
    margin-bottom: 3px;
}
.time-icon { 
	
	width: 20px; 
	height: 20px; 
	margin-right: 5px;
	
}
/* Hap Etiket (Pill) Ana Tasarımı */
.status-pill {
    padding: 5px 12px;
    border-radius: 15px; 
    font-size: 11px;
    font-weight: bold;
    color: white;
    text-align: center;
    
}

/* ❗️ Senin Enum ID'lerine Göre Dinamik Renkler */
.status-1 { background-color: #ffc107; color: black; } /* 1: Planlandı - Sarı */
.status-2 { background-color: #28a745; }               /* 2: Tamamlandı - Yeşil */
.status-3 { background-color: #6c757d; }               /* 3: İptal - Gri */
.status-4 { background-color: #dc3545; }               /* 4: Gelmedi - Kırmızı */
.status-0 { background-color: #e9ecef; color: #6c757d; border: 1px solid #ced4da; } /* 0: Yok - Soluk Gri */</value>
  </data>
  <data name="tileView1.TileHtmlTemplate.Template" xml:space="preserve">
    <value>&lt;div class="card-container"&gt;
    &lt;div class="info-section"&gt;
        &lt;div class="customer-name"&gt;${CustomerName}&lt;/div&gt;
    	&lt;div class="phone-number"&gt;${PhoneNumber}&lt;/div&gt;
        &lt;div class="service-detail"&gt;${ServiceName}&lt;/div&gt;
        &lt;div class="time-detail"&gt;
        	&lt;img src="clockIcon" class="time-icon"/&gt;
        	&lt;span class="time-text"&gt;${TimeDisplay}&lt;/span&gt;
        	
        &lt;/div&gt;
    	
    &lt;/div&gt;
    
    &lt;div class="status-section"&gt;
        &lt;div class="status-pill" dx-class="{StatusCssClass}"&gt;${StatusText}&lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;</value>
  </data>
